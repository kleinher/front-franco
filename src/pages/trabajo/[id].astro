---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map(p => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const project = projects.find(p => p.id === id)!;
const currentIndex = projects.findIndex(p => p.id === id);
const prev = currentIndex > 0 ? projects[currentIndex - 1] : null;
const next = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null;

// Layout de galería: primera imagen full width, luego pares, última sola si impar
const [first, ...rest] = project.gallery;
const pairs: string[][] = [];
for (let i = 0; i < rest.length - 1; i += 2) {
  pairs.push([rest[i], rest[i + 1]]);
}
const lastSingle = rest.length % 2 !== 0 ? rest[rest.length - 1] : null;
---
<Layout title={`${project.title} — Franco García`}>

  <!-- Nav -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-neutral-100">
    <nav class="flex items-center justify-between px-5 md:px-8 h-12">
      <a href="/" class="text-[10px] tracking-widest uppercase text-neutral-400 hover:text-neutral-900 transition-colors flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="flex-shrink-0">
          <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Proyectos
      </a>
      <span class="text-[10px] tracking-widest uppercase text-neutral-400 hidden md:block">
        Franco García
      </span>
      <!-- Navegación entre proyectos -->
      <div class="flex items-center gap-5">
        {prev && (
          <a href={`/trabajo/${prev.id}`} class="text-[10px] tracking-widest uppercase text-neutral-400 hover:text-neutral-900 transition-colors flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M7 1.5L2.5 6L7 10.5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
            </svg>
            Anterior
          </a>
        )}
        {next && (
          <a href={`/trabajo/${next.id}`} class="text-[10px] tracking-widest uppercase text-neutral-400 hover:text-neutral-900 transition-colors flex items-center gap-1.5">
            Siguiente
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M5 1.5L9.5 6L5 10.5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
            </svg>
          </a>
        )}
      </div>
    </nav>
  </header>

  <main class="pt-12">

    <!-- Título del proyecto -->
    <div class="px-5 md:px-8 py-8 md:py-12 border-b border-neutral-100 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end">
      <div>
        <p class="text-[10px] tracking-widest uppercase text-neutral-400 mb-2">
          {project.category}&ensp;—&ensp;{project.year}
        </p>
        <h1 class="text-2xl md:text-3xl font-light text-neutral-900">{project.title}</h1>
      </div>
      <div class="text-right">
        <p class="text-[10px] tracking-widest uppercase text-neutral-400">{project.location}</p>
        <p class="text-xs text-neutral-500 font-light mt-1 max-w-xs md:text-right">{project.description}</p>
      </div>
    </div>

    <!-- Primera imagen — full width -->
    <div class="w-full">
      <img
        src={first}
        alt={`${project.title} — imagen principal`}
        class="w-full aspect-[16/9] object-cover"
      />
    </div>

    <!-- Pares de imágenes -->
    {pairs.map(([a, b]) => (
      <div class="grid grid-cols-2">
        <img
          src={a}
          alt={project.title}
          class="w-full aspect-[4/3] object-cover"
          loading="lazy"
        />
        <img
          src={b}
          alt={project.title}
          class="w-full aspect-[4/3] object-cover"
          loading="lazy"
        />
      </div>
    ))}

    <!-- Última imagen sola (si el total de rest es impar) -->
    {lastSingle && (
      <div class="w-full">
        <img
          src={lastSingle}
          alt={project.title}
          class="w-full aspect-[16/9] object-cover"
          loading="lazy"
        />
      </div>
    )}

    <!-- Navegación inferior entre proyectos -->
    <div class="border-t border-neutral-100 grid grid-cols-2">
      <div class="border-r border-neutral-100 p-6 md:p-10">
        {prev ? (
          <a href={`/trabajo/${prev.id}`} class="group flex flex-col gap-1">
            <span class="text-[10px] tracking-widest uppercase text-neutral-300">Anterior</span>
            <span class="text-sm font-light text-neutral-900 group-hover:text-neutral-500 transition-colors">{prev.title}</span>
          </a>
        ) : <span />}
      </div>
      <div class="p-6 md:p-10 text-right">
        {next ? (
          <a href={`/trabajo/${next.id}`} class="group flex flex-col gap-1 items-end">
            <span class="text-[10px] tracking-widest uppercase text-neutral-300">Siguiente</span>
            <span class="text-sm font-light text-neutral-900 group-hover:text-neutral-500 transition-colors">{next.title}</span>
          </a>
        ) : <span />}
      </div>
    </div>

  </main>

  <footer class="border-t border-neutral-100 px-5 md:px-8 py-5">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-2 text-[10px] tracking-widest uppercase text-neutral-300">
      <p>Franco García Visualización</p>
      <p>Buenos Aires, Argentina</p>
      <p>© {new Date().getFullYear()}</p>
    </div>
  </footer>

</Layout>
