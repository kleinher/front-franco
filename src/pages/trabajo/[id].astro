---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map(p => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const project = projects.find(p => p.id === id)!;
const currentIndex = projects.findIndex(p => p.id === id);
const prev = currentIndex > 0 ? projects[currentIndex - 1] : null;
const next = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null;

const [first, ...rest] = project.gallery;
const pairs: string[][] = [];
for (let i = 0; i < rest.length - 1; i += 2) {
  pairs.push([rest[i], rest[i + 1]]);
}
const lastSingle = rest.length % 2 !== 0 ? rest[rest.length - 1] : null;
---
<Layout title={`${project.title} — mud`}>

  <!-- Nav transparente igual que home -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-black/35 backdrop-blur-sm">
    <nav class="flex items-center justify-between px-5 md:px-8 h-14" style="text-shadow: 0 1px 4px rgba(0,0,0,0.45)">
      <a href="/" class="flex items-center gap-3 group opacity-75 hover:opacity-100 transition-opacity duration-200">
        <svg width="42" height="28" viewBox="0 0 54 34" fill="none" aria-hidden="true">
          <rect x="1" y="4" width="26" height="7" fill="white"/>
          <rect x="23" y="22" width="26" height="7" fill="white"/>
          <path d="M1 4 H49 V11 H27 V22 H49 V29 H1 V22 H23 V11 H1 Z"
                stroke="white" stroke-width="0.75" fill="none" opacity="0.35"/>
        </svg>
        <span class="w-px h-5 bg-white/25 flex-shrink-0"></span>
        <span class="text-white/50 text-sm font-light tracking-widest lowercase group-hover:text-white/80 transition-colors duration-200">mud</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/" class="text-[11px] tracking-widest uppercase text-white hover:text-white/60 transition-colors flex items-center gap-2">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="flex-shrink-0">
            <path d="M8 2L3 6L8 10" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
          </svg>
          <span class="i18n-es">Proyectos</span>
          <span class="i18n-en">Work</span>
        </a>
        <div class="hidden md:flex items-center gap-6">
          {prev && (
            <a href={`/trabajo/${prev.id}`} class="text-[11px] tracking-widest uppercase text-white/50 hover:text-white transition-colors flex items-center gap-1.5">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M8 2L3 6L8 10" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
              </svg>
              <span class="i18n-es">Anterior</span>
              <span class="i18n-en">Previous</span>
            </a>
          )}
          {next && (
            <a href={`/trabajo/${next.id}`} class="text-[11px] tracking-widest uppercase text-white/50 hover:text-white transition-colors flex items-center gap-1.5">
              <span class="i18n-es">Siguiente</span>
              <span class="i18n-en">Next</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M4 2L9 6L4 10" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
              </svg>
            </a>
          )}
        </div>
        <div class="lang-pill flex items-center rounded-full border border-white/20 overflow-hidden text-[10px] tracking-widest uppercase">
          <button data-set-lang="es" class="lang-opt px-3 py-1.5 transition-colors duration-150">ES</button>
          <button data-set-lang="en" class="lang-opt px-3 py-1.5 transition-colors duration-150">EN</button>
        </div>
      </div>
    </nav>
  </header>

  <main>

    <!-- Primera imagen — full width, cubre el nav -->
    <div class="w-full">
      <img
        src={first}
        alt={`${project.title} — imagen principal`}
        class="w-full aspect-[16/9] object-cover"
      />
    </div>

    <!-- Metadata del proyecto -->
    <div class="px-5 md:px-8 py-8 md:py-10 border-b border-neutral-100 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-start">
      <div>
        <p class="text-[10px] tracking-widest uppercase text-neutral-400 mb-2">
          <span class="i18n-es">{project.category}</span>
          <span class="i18n-en">{project.category_en}</span>
          &ensp;—&ensp;{project.year}
        </p>
        <h1 class="text-xl md:text-2xl font-light text-neutral-900">{project.title}</h1>
      </div>
      <div class="md:text-right max-w-xs">
        <p class="text-[10px] tracking-widest uppercase text-neutral-400 mb-1">{project.location}</p>
        <p class="text-xs text-neutral-500 font-light leading-relaxed i18n-es">{project.description}</p>
        <p class="text-xs text-neutral-500 font-light leading-relaxed i18n-en">{project.description_en}</p>
      </div>
    </div>

    <!-- Pares de imágenes con gap de 1px -->
    <div class="p-1 space-y-1">
      {pairs.map(([a, b]) => (
        <div class="grid grid-cols-2 gap-1">
          <img src={a} alt={project.title} class="w-full aspect-[4/3] object-cover" loading="lazy" />
          <img src={b} alt={project.title} class="w-full aspect-[4/3] object-cover" loading="lazy" />
        </div>
      ))}
      {lastSingle && (
        <img src={lastSingle} alt={project.title} class="w-full aspect-[16/9] object-cover" loading="lazy" />
      )}
    </div>

    <!-- Navegación inferior -->
    <div class="border-t border-neutral-100 grid grid-cols-2">
      <div class="border-r border-neutral-100 p-6 md:p-10">
        {prev ? (
          <a href={`/trabajo/${prev.id}`} class="group flex flex-col gap-1">
            <span class="text-[10px] tracking-widest uppercase text-neutral-300 i18n-es">Anterior</span>
            <span class="text-[10px] tracking-widest uppercase text-neutral-300 i18n-en">Previous</span>
            <span class="text-sm font-light text-neutral-900 group-hover:text-neutral-400 transition-colors">{prev.title}</span>
          </a>
        ) : <span />}
      </div>
      <div class="p-6 md:p-10 text-right">
        {next ? (
          <a href={`/trabajo/${next.id}`} class="group flex flex-col gap-1 items-end">
            <span class="text-[10px] tracking-widest uppercase text-neutral-300 i18n-es">Siguiente</span>
            <span class="text-[10px] tracking-widest uppercase text-neutral-300 i18n-en">Next</span>
            <span class="text-sm font-light text-neutral-900 group-hover:text-neutral-400 transition-colors">{next.title}</span>
          </a>
        ) : <span />}
      </div>
    </div>

  </main>

  <footer class="border-t border-neutral-100 px-5 md:px-8 py-5">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-2 text-[10px] tracking-widest uppercase text-neutral-300">
      <p>mud</p>
      <p>Berlín &ensp;—&ensp; Cádiz &ensp;—&ensp; Buenos Aires</p>
      <p>© {new Date().getFullYear()}</p>
    </div>
  </footer>

</Layout>
