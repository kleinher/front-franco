---
interface Props {
  title?: string;
}
const { title = 'mud — Visualización Arquitectónica' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <!-- Aplica idioma antes del paint para evitar flash -->
    <script is:inline>
      (function() {
        const l = localStorage.getItem('lang') || 'es';
        if (l === 'en') document.documentElement.classList.add('lang-en');
      })();
    </script>
    <style>
      html:not(.lang-en) .i18n-en { display: none !important; }
      html.lang-en .i18n-es { display: none !important; }
    </style>
  </head>
  <body class="bg-white text-neutral-900 font-sans antialiased">
    <slot />
    <script>
      function setLang(lang: string) {
        document.documentElement.classList.toggle('lang-en', lang === 'en');
        localStorage.setItem('lang', lang);
        document.querySelectorAll<HTMLElement>('[data-lang-indicator]').forEach(el => {
          el.textContent = lang === 'es' ? 'EN' : 'ES';
        });
      }

      const stored = localStorage.getItem('lang') || 'es';
      setLang(stored);

      document.querySelectorAll('[data-lang-toggle]').forEach(btn => {
        btn.addEventListener('click', () => {
          const current = localStorage.getItem('lang') || 'es';
          setLang(current === 'es' ? 'en' : 'es');
        });
      });
    </script>
  </body>
</html>
