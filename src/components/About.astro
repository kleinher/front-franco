---
import type { TeamMember } from '../data/team';

interface Props {
  team: TeamMember[];
}
const { team } = Astro.props;
---
<section id="nosotros" class="border-t border-neutral-100">

  <!-- Texto intro -->
  <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] border-b border-neutral-100">
    <div class="px-5 md:px-8 py-14 md:py-20 border-b md:border-b-0 md:border-r border-neutral-100">
      <span class="text-[10px] tracking-widest uppercase text-neutral-400">Nosotros</span>
    </div>
    <div class="px-7 md:px-16 py-14 md:py-20 grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
      <div class="space-y-5 text-xs text-neutral-500 font-light leading-relaxed">
        <p>
          Somos un estudio de visualización arquitectónica fundado en Buenos Aires. Producimos renders fotorrealistas, animaciones y material visual para estudios de arquitectura, desarrolladoras y constructoras.
        </p>
        <p>
          Cada imagen es una oportunidad para mostrar un proyecto antes de que exista. Trabajamos con la arquitectura como punto de partida y la imagen como resultado final.
        </p>
      </div>
      <div class="grid grid-cols-3 gap-6 md:gap-10">
        <div>
          <p class="text-2xl font-light text-neutral-900">+80</p>
          <p class="text-[10px] tracking-widest uppercase text-neutral-400 mt-1">Proyectos</p>
        </div>
        <div>
          <p class="text-2xl font-light text-neutral-900">8</p>
          <p class="text-[10px] tracking-widest uppercase text-neutral-400 mt-1">Años</p>
        </div>
        <div>
          <p class="text-2xl font-light text-neutral-900">5</p>
          <p class="text-[10px] tracking-widest uppercase text-neutral-400 mt-1">Países</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Equipo -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-x divide-neutral-100">
    {team.map(member => (
      <div class="group border-b border-neutral-100 lg:border-b-0">
        <div class="aspect-[3/4] overflow-hidden">
          <img
            src={member.image}
            alt={member.name}
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 group-hover:scale-[1.03]"
            loading="lazy"
          />
        </div>
        <div class="px-5 py-6">
          <p class="text-xs text-neutral-900 font-normal">{member.name}</p>
          <p class="text-[10px] text-neutral-400 tracking-wide mt-1">{member.role}</p>
          <p class="text-[11px] text-neutral-400 leading-relaxed mt-3 font-light">{member.bio}</p>
        </div>
      </div>
    ))}
  </div>

</section>
