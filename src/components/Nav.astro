---
const links = [
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#contacto', label: 'Contacto' },
];
---
<header class="fixed top-0 left-0 right-0 z-50 mix-blend-difference">
  <nav class="flex items-center justify-between px-6 md:px-12 py-6">
    <a href="/" class="text-white text-sm font-medium tracking-widest uppercase">
      <!-- Reemplazar con el nombre del estudio -->
      García &amp; Ríos Ingeniería
    </a>
    <ul class="hidden md:flex gap-10">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="text-white text-sm tracking-wide hover:opacity-60 transition-opacity duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <!-- Menú mobile -->
    <button
      id="menu-btn"
      class="md:hidden text-white flex flex-col gap-1.5"
      aria-label="Abrir menú"
    >
      <span class="w-6 h-px bg-white block transition-all" id="line1"></span>
      <span class="w-6 h-px bg-white block transition-all" id="line2"></span>
    </button>
  </nav>
</header>

<!-- Menú mobile overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-neutral-950 flex flex-col items-center justify-center gap-10 translate-x-full transition-transform duration-300 ease-in-out"
>
  {links.map(link => (
    <a
      href={link.href}
      class="mobile-link text-white text-3xl font-light tracking-widest uppercase"
    >
      {link.label}
    </a>
  ))}
</div>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');
  let open = false;

  btn?.addEventListener('click', () => {
    open = !open;
    menu?.classList.toggle('translate-x-full', !open);
    if (line1 && line2) {
      line1.style.transform = open ? 'translateY(4px) rotate(45deg)' : '';
      line2.style.transform = open ? 'translateY(-4px) rotate(-45deg)' : '';
    }
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      open = false;
      menu?.classList.add('translate-x-full');
      if (line1 && line2) {
        line1.style.transform = '';
        line2.style.transform = '';
      }
    });
  });
</script>
