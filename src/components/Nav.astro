---
const links = [
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#contacto', label: 'Contacto' },
];
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-neutral-100">
  <nav class="flex items-center justify-between px-5 md:px-8 h-12">
    <a href="/" class="text-xs tracking-widest uppercase text-neutral-900 font-normal">
      Franco García
    </a>
    <ul class="hidden md:flex gap-8">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="text-xs tracking-wide text-neutral-500 hover:text-neutral-900 transition-colors duration-150"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-[5px] p-1"
      aria-label="Menú"
    >
      <span class="w-5 h-px bg-neutral-900 block transition-all duration-200" id="line1"></span>
      <span class="w-5 h-px bg-neutral-900 block transition-all duration-200" id="line2"></span>
    </button>
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-white flex flex-col items-start justify-end px-5 pb-14 gap-6 translate-y-full transition-transform duration-300 ease-in-out"
>
  {links.map(link => (
    <a href={link.href} class="mobile-link text-2xl font-light text-neutral-900 tracking-wide">
      {link.label}
    </a>
  ))}
</div>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');
  let open = false;

  btn?.addEventListener('click', () => {
    open = !open;
    menu?.classList.toggle('translate-y-full', !open);
    if (line1 && line2) {
      line1.style.transform = open ? 'translateY(3px) rotate(45deg)' : '';
      line2.style.transform = open ? 'translateY(-3px) rotate(-45deg)' : '';
    }
  });

  document.querySelectorAll('.mobile-link').forEach(l => {
    l.addEventListener('click', () => {
      open = false;
      menu?.classList.add('translate-y-full');
      if (line1 && line2) { line1.style.transform = ''; line2.style.transform = ''; }
    });
  });
</script>
