---
import type { Project } from '../data/projects';

interface Props {
  projects: Project[];
}
const { projects } = Astro.props;
---
<section id="proyectos">
  <div class="grid grid-cols-1 md:grid-cols-2">
    {projects.map((project) => (
      <a href={`/trabajo/${project.id}`} class="group relative overflow-hidden block">
        <div class="aspect-[4/3]">
          <img
            src={project.image}
            alt={project.title}
            class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-[1.03]"
            loading="lazy"
          />
        </div>
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/50 transition-colors duration-400 flex flex-col justify-end p-7 md:p-9">
          <div class="opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300 ease-out">
            <p class="text-white/60 text-[10px] tracking-widest uppercase mb-1.5">
              {project.category}&ensp;—&ensp;{project.year}
            </p>
            <h3 class="text-white text-lg font-light leading-snug">{project.title}</h3>
            <p class="text-white/70 text-xs font-light mt-1">{project.location}</p>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
