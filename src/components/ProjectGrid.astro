---
import type { Project } from '../data/projects';

interface Props {
  projects: Project[];
}
const { projects } = Astro.props;
---
<section id="proyectos" class="py-24 px-6 md:px-12">
  <div class="mb-12 flex items-end justify-between">
    <h2 class="text-2xl md:text-3xl font-light tracking-wide">Proyectos</h2>
    <span class="text-neutral-400 text-sm">{projects.length} trabajos</span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-neutral-200">
    {projects.map((project) => (
      <article class="group relative overflow-hidden bg-white cursor-pointer">
        <div class="aspect-[4/3] overflow-hidden">
          <img
            src={project.image}
            alt={project.title}
            class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <!-- overlay on hover -->
        <div class="absolute inset-0 bg-neutral-950/0 group-hover:bg-neutral-950/60 transition-colors duration-500 flex items-end p-8">
          <div class="translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-400 ease-out">
            <p class="text-neutral-400 text-xs tracking-widest uppercase mb-1">
              {project.category} — {project.year}
            </p>
            <p class="text-white text-sm font-light leading-relaxed max-w-xs">
              {project.description}
            </p>
          </div>
        </div>
        <!-- título siempre visible abajo -->
        <div class="p-6 bg-white group-hover:bg-neutral-950 transition-colors duration-500">
          <p class="text-xs text-neutral-400 tracking-widest uppercase mb-1 group-hover:text-neutral-500">
            {project.location}
          </p>
          <h3 class="text-base font-light group-hover:text-white transition-colors duration-500">
            {project.title}
          </h3>
        </div>
      </article>
    ))}
  </div>
</section>
