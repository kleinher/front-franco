---
import type { Project } from '../data/projects';

interface Props {
  projects: Project[];
}
const { projects } = Astro.props;

// Layout de filas: 3 - 4 - 2 (total 9)
const ROW_SIZES = [3, 4, 2];
const rows: Project[][] = [];
let idx = 0;
for (const size of ROW_SIZES) {
  const row = projects.slice(idx, idx + size);
  if (row.length) rows.push(row);
  idx += size;
}
// Si quedan proyectos fuera del patrón, los agrupamos al final
if (idx < projects.length) rows.push(projects.slice(idx));

const colClass: Record<number, string> = {
  1: 'grid-cols-1',
  2: 'grid-cols-2',
  3: 'grid-cols-3',
  4: 'grid-cols-4',
};
---
<section id="proyectos" class="p-1">
  {rows.map(row => (
    <div class={`grid gap-1 ${colClass[row.length] ?? 'grid-cols-2'}`}>
      {row.map(project => (
        <a href={`/trabajo/${project.id}`} class="group relative overflow-hidden block">
          <div class="aspect-[4/3]">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-[1.03]"
              loading="lazy"
            />
          </div>
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/50 transition-colors duration-400 flex flex-col justify-end p-5 md:p-7">
            <div class="opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300 ease-out">
              <p class="text-white/60 text-[9px] tracking-widest uppercase mb-1">
                <span class="i18n-es">{project.category}</span>
                <span class="i18n-en">{project.category_en}</span>
                &ensp;—&ensp;{project.year}
              </p>
              <h3 class="text-white text-sm md:text-base font-light leading-snug">{project.title}</h3>
            </div>
          </div>
        </a>
      ))}
    </div>
  ))}
</section>
