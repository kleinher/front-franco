---
import type { Service } from '../data/services';

interface Props {
  services: Service[];
}
const { services } = Astro.props;
---
<section id="servicios" class="py-24 px-6 md:px-12 bg-neutral-950 text-white">
  <div class="mb-16">
    <h2 class="text-2xl md:text-3xl font-light tracking-wide">Servicios</h2>
    <p class="text-neutral-400 mt-4 max-w-lg font-light leading-relaxed">
      Brindamos soluciones integrales de ingeniería, desde la concepción del proyecto hasta la dirección de obra.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-neutral-800">
    {services.map((service, i) => (
      <div class="bg-neutral-950 p-10 hover:bg-neutral-900 transition-colors duration-300 group">
        <span class="text-neutral-600 text-xs tracking-widest uppercase mb-6 block">
          0{i + 1}
        </span>
        <h3 class="text-xl font-light mb-4 group-hover:text-neutral-200 transition-colors">
          {service.title}
        </h3>
        <p class="text-neutral-400 text-sm leading-relaxed mb-8 font-light">
          {service.description}
        </p>
        <ul class="space-y-2">
          {service.items.map(item => (
            <li class="flex items-start gap-3 text-neutral-500 text-sm">
              <span class="mt-2 w-1 h-1 rounded-full bg-neutral-600 flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
