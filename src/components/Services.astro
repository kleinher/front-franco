---
import type { Service } from '../data/services';

interface Props {
  services: Service[];
}
const { services } = Astro.props;
---
<section id="servicios" class="border-t border-neutral-100">
  <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] min-h-0">

    <!-- Etiqueta lateral -->
    <div class="px-5 md:px-8 py-14 md:py-20 border-b md:border-b-0 md:border-r border-neutral-100">
      <span class="text-[10px] tracking-widest uppercase text-neutral-400">Servicios</span>
    </div>

    <!-- Grid de servicios -->
    <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-neutral-100">
      {services.map((service, i) => (
        <div class="px-7 md:px-10 py-14 md:py-20 group border-b border-neutral-100 last:border-b-0 sm:[&:nth-child(n+3)]:border-t sm:[&:nth-child(n+3)]:border-neutral-100">
          <p class="text-[10px] tracking-widest uppercase text-neutral-300 mb-8">0{i + 1}</p>
          <h3 class="text-sm font-normal text-neutral-900 mb-4">{service.title}</h3>
          <p class="text-xs text-neutral-400 leading-relaxed mb-7 font-light max-w-xs">
            {service.description}
          </p>
          <ul class="space-y-2.5">
            {service.items.map(item => (
              <li class="text-[11px] text-neutral-400 font-light flex items-center gap-2.5">
                <span class="w-3 h-px bg-neutral-300 flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>
