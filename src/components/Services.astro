---
import type { Service } from '../data/services';

interface Props {
  services: Service[];
}
const { services } = Astro.props;
---
<section id="servicios" class="border-t border-neutral-100">
  <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] min-h-0">

    <div class="px-5 md:px-8 py-14 md:py-20 border-b md:border-b-0 md:border-r border-neutral-100">
      <span class="text-[10px] tracking-widest uppercase text-neutral-400 i18n-es">Servicios</span>
      <span class="text-[10px] tracking-widest uppercase text-neutral-400 i18n-en">Services</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-neutral-100">
      {services.map((service, i) => (
        <div class="px-7 md:px-10 py-14 md:py-20 border-b border-neutral-100 sm:last:border-b-0">
          <p class="text-[10px] tracking-widest uppercase text-neutral-300 mb-8">0{i + 1}</p>
          <h3 class="text-sm font-normal text-neutral-900 mb-4">
            <span class="i18n-es">{service.title}</span>
            <span class="i18n-en">{service.title_en}</span>
          </h3>
          <p class="text-xs text-neutral-400 leading-relaxed font-light max-w-xs">
            <span class="i18n-es">{service.description}</span>
            <span class="i18n-en">{service.description_en}</span>
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
